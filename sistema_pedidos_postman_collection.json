          "request": {
            "method": "GET",
            "header": [
               { "key": "Accept", "value": "application/json", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/pedidos/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pedidos", "1"]
